# Base URL of the events-curator API (no trailing slash).
VITE_CURATOR_BASE_URL=http://127.0.0.1:8000

# Public URL of the worker's `ingestFromExtension` webhook. After
# `ntn workers deploy`, find this URL via `ntn workers capabilities list`
# (or in the Notion workspace settings). For local testing the webhook
# isn't HTTP-exposed; use `ntn workers exec ingestFromExtension --local`
# to invoke it directly.
VITE_WORKER_WEBHOOK_URL=

# Must match `EXTENSION_WEBHOOK_SECRET` in worker/.env. Generate with:
#   openssl rand -hex 32
VITE_WORKER_WEBHOOK_SECRET=
