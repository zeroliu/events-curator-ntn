FIRECRAWL_API_KEY=your-firecrawl-api-key-here
APOLLO_API_KEY=your-apollo-api-key-here

# Comma-separated enricher order. Default is `agent_enricher`, which uses the
# locally-installed Claude Code CLI (run `claude login` once). Other choices:
# heuristic, website_llm, apollo. Example: CURATOR_ENRICHERS=agent_enricher,heuristic
# CURATOR_ENRICHERS=agent_enricher
